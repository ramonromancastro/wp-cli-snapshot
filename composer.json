{
  "name": "ramonromancastro/wp-cli-snapshot",
  "description": "Declarative state management for WordPress. Export, validate, and apply environment states.",
  "type": "wp-cli-package",
  "homepage": "https://github.com/ramonromancastro/wp-cli-snapshot",
  "support": {
    "issues": "https://github.com/ramonromancastro/wp-cli-snapshot/issues"
  },
  "license": "MIT",
  "authors": [
    {
      "name": "Ramón Román Castro",
      "email": "ramonromancastro@gmail.com",
      "homepage": "https://www.rrc2software.org"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "wp-cli/wp-cli": "^2.8"
  },
  "autoload": {
    "psr-4": {
      "WPCliSnapshot\\": "src/"
    },
    "files": [
      "snapshot-command.php"
    ]
  },
  "extra": {
    "branch-alias": {
      "dev-main": "0.x-dev"
    },
    "commands": [
      "snapshot apply",
      "snapshot export",
      "snapshot validate"
    ]
  }
}
